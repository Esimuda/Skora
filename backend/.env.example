# ── Database (Supabase transaction pooler) ────────────────────────────────────
DB_HOST=aws-1-eu-central-1.pooler.supabase.com
DB_PORT=6543
DB_USERNAME=postgres.YOUR_PROJECT_REF
DB_PASSWORD=YOUR_SUPABASE_PASSWORD
DB_DATABASE=postgres

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('base64url'))"
JWT_SECRET=REPLACE_WITH_STRONG_SECRET_MIN_64_CHARS
JWT_EXPIRES_IN=7d

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
# Set to true ONLY on first deployment to auto-create DB tables, then remove it
# DB_SYNCHRONIZE=true

# ── CORS — comma-separated list of allowed frontend origins ───────────────────
FRONTEND_URL=https://your-app.vercel.app

# ── Email (Brevo HTTP API — for teacher invites and result alerts) ────────────
# Brevo's HTTPS API works on Render/Vercel/etc., where outbound SMTP is blocked.
# Free tier: 300 emails/day, no domain required.
# 1. Sign up at https://www.brevo.com — verify your inbox.
# 2. Verify a sender at https://app.brevo.com/senders/list — Brevo emails you a
#    code; enter it. The verified address is what you put in MAIL_FROM.
# 3. Create an API key at https://app.brevo.com/settings/keys/api (xkeysib-...).
BREVO_API_KEY=xkeysib-REPLACE_WITH_YOUR_API_KEY
MAIL_FROM=Skora RMS <your-verified-sender@gmail.com>
