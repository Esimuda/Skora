# ── Database (Supabase transaction pooler) ────────────────────────────────────
DB_HOST=aws-1-eu-central-1.pooler.supabase.com
DB_PORT=6543
DB_USERNAME=postgres.YOUR_PROJECT_REF
DB_PASSWORD=YOUR_SUPABASE_PASSWORD
DB_DATABASE=postgres

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('base64url'))"
JWT_SECRET=REPLACE_WITH_STRONG_SECRET_MIN_64_CHARS
JWT_EXPIRES_IN=7d

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
# Set to true ONLY on first deployment to auto-create DB tables, then remove it
# DB_SYNCHRONIZE=true

# ── CORS — comma-separated list of allowed frontend origins ───────────────────
FRONTEND_URL=https://your-app.vercel.app

# ── Email (optional — for teacher invite emails) ──────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-gmail@gmail.com
# Gmail: use an App Password, not your real password
# https://myaccount.google.com/apppasswords
MAIL_PASS=your-app-password
MAIL_FROM=Skora RMS <your-gmail@gmail.com>
