# ── Database (Supabase transaction pooler) ────────────────────────────────────
DB_HOST=aws-1-eu-central-1.pooler.supabase.com
DB_PORT=6543
DB_USERNAME=postgres.YOUR_PROJECT_REF
DB_PASSWORD=YOUR_SUPABASE_PASSWORD
DB_DATABASE=postgres

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('base64url'))"
JWT_SECRET=REPLACE_WITH_STRONG_SECRET_MIN_64_CHARS
JWT_EXPIRES_IN=7d

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
# Set to true ONLY on first deployment to auto-create DB tables, then remove it
# DB_SYNCHRONIZE=true

# ── CORS — comma-separated list of allowed frontend origins ───────────────────
FRONTEND_URL=https://your-app.vercel.app

# ── Email (Gmail SMTP — for teacher invites and result alerts) ────────────────
# 1. Enable 2-Step Verification on the Gmail account you want to send from.
# 2. Create an App Password at https://myaccount.google.com/apppasswords
#    (16 characters, no spaces — paste it into MAIL_PASS exactly).
# 3. Gmail allows ~500 outgoing emails / day on a free account.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-gmail@gmail.com
MAIL_PASS=your-16-char-app-password
MAIL_FROM=Skora RMS <your-gmail@gmail.com>
