# ── Database ──────────────────────────────────────────────────────────────────
# Option A — full DATABASE_URL (Supabase / Railway / Render connection string)
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_SUPABASE_PASSWORD@aws-1-eu-central-1.pooler.supabase.com:6543/postgres

# Option B — individual fields (used by data-source.ts for TypeORM CLI migrations)
DB_HOST=aws-1-eu-central-1.pooler.supabase.com
DB_PORT=6543
DB_USERNAME=postgres.YOUR_PROJECT_REF
DB_PASSWORD=YOUR_SUPABASE_PASSWORD
DB_DATABASE=postgres

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('base64url'))"
JWT_SECRET=REPLACE_WITH_STRONG_SECRET_MIN_64_CHARS
JWT_EXPIRES_IN=7d

# ── Super Admin ───────────────────────────────────────────────────────────────
# The email address that will automatically be assigned the super_admin role on signup.
# Set this BEFORE signing up with that email address.
SUPER_ADMIN_EMAIL=your-admin@example.com

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
# Set to true ONLY on first deployment to auto-create DB tables, then remove it
# DB_SYNCHRONIZE=true

# ── CORS — frontend origin ────────────────────────────────────────────────────
FRONTEND_URL=https://your-app.vercel.app

# ── Email (Resend HTTP API) ───────────────────────────────────────────────────
# Resend's HTTPS API works on Render/Vercel/etc., where outbound SMTP is blocked.
# Free tier: 100 emails/day, 3,000/month. Requires a verified domain you control.
# 1. Sign up at https://resend.com
# 2. Add your domain at https://resend.com/domains — Resend shows DKIM/SPF DNS
#    records to add at your registrar. Wait for DNS to propagate, then click
#    Verify until it goes green.
# 3. Create an API key at https://resend.com/api-keys (re_...).
RESEND_API_KEY=re_REPLACE_WITH_YOUR_API_KEY
MAIL_FROM=Skora RMS <noreply@yourdomain.xyz>
